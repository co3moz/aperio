# ==============================================================================
# APERIO ENVIRONMENT VARIABLES REFERENCE (.env.example)
# ==============================================================================
# Copy this file to .env in your respective running directory or set these in your shell.

# ------------------------------------------------------------------------------
# APERIO SERVER CONFIGURATION (aperio-server)
# ------------------------------------------------------------------------------

# [REQUIRED] The secret authentication token that clients must provide in order
# to connect. Handshake attempts without this token are instantly rejected.
APERIO_SERVER_TOKEN=super-secret-token-change-me

# The address to bind the Aperio server to. Defaults to all interfaces.
HOST=0.0.0.0

# The port on which the Aperio server will listen for public traffic.
PORT=8080

# Set to "true" or "1" to enable the built-in traffic dashboard and metrics APIs.
APERIO_DASHBOARD=1

# The grace period (in seconds) to wait for a tunnel client to reconnect
# when a request comes in while the client is offline.
APERIO_SERVER_GATEWAY_TIMEOUT=10

# The timeout (in seconds) the server will wait for the client to complete
# proxying the request and return a response back over the WebSocket.
APERIO_SERVER_GATEWAY_RESPONSE_TIMEOUT=30

# Maximum request body size in bytes. (Default is 10485760 bytes = 10 MB)
APERIO_MAX_BODY_SIZE=10485760

# Max concurrent requests in-flight on the server.
APERIO_MAX_CONCURRENT_REQUESTS=100

# Max connected client tunnels to prevent resource exhaustion.
APERIO_MAX_TUNNELS=10

# Per-IP Rate Limiting (Token Bucket)
# Maximum burst request capacity per client IP address.
APERIO_IP_LIMIT_MAX=100.0

# Rate at which tokens are refilled per second (e.g. 5.0 tokens/sec = 300 req/min).
APERIO_IP_LIMIT_REFILL=5.0

# Logging Level
# Available values: error, warn, info, debug, trace
RUST_LOG=info,aperio_server=debug


# ------------------------------------------------------------------------------
# APERIO CLIENT CONFIGURATION (aperio-client)
# ------------------------------------------------------------------------------

# [REQUIRED] Token matching the APERIO_SERVER_TOKEN of the server.
# APERIO_SERVER_TOKEN=super-secret-token-change-me

# Public URL of the running Aperio proxy server.
APERIO_SERVER=http://localhost:8080

# Address of your local server target to route the public traffic to.
APERIO_CLIENT_TARGET=http://127.0.0.1:3000

# Set to "1" to forward the original HTTP "Host" header sent by the public user
# to your target backend. If "0" (default), Host header will be rewritten to match APERIO_CLIENT_TARGET.
APERIO_CLIENT_PASS_HOSTNAME=0

# Logging Level
# RUST_LOG=info,aperio_client=debug
